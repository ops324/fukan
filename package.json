{
  "name": "axiom-ai-pipeline",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "俯瞰（FUKAN）— ヘッドレス Claude が各分野のニュースを取材・執筆し、画像付与・静的サイト生成まで自動化するパイプライン",
  "scripts": {
    "candidates": "node src/fetchCandidates.js",
    "ingest": "node src/ingestDrafts.js",
    "build": "node src/build.js",
    "render": "node src/renderOnly.js",
    "migrate-sections": "node src/migrateSections.js",
    "check": "node src/check.js",
    "evaluate": "node src/evaluate.js",
    "quality-digest": "node src/qualityDigest.js",
    "backfill-images": "node src/backfill-images.js",
    "set-press-image": "node src/set-press-image.js",
    "serve": "npm run build && python3 -m http.server 8000 --directory dist"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "marked": "^15.0.6",
    "rss-parser": "^3.13.0"
  }
}
